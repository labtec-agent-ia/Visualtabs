class CampaignAutomation:
    def __init__(self):
        self.rules = []
    
    def add_rule(self, condition, action, priority=1):
        """Adiciona regra de automação"""
        self.rules.append({
            "condition": condition,
            "action": action,
            "priority": priority
        })
    
    def evaluate_rules(self, campaign):
        """Avalia regras para automatizar campanha"""
        actions = []
        for rule in sorted(self.rules, key=lambda x: x["priority"]):
            if rule["condition"](campaign):
                actions.append(rule["action"])
        return actions
